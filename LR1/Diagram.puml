@startuml
class Client {
- {static} AtomicLong nextId
- long id
- String fullName
- String email
- String address
+ String getFullName()
+ void setFullName(String)
+ String getEmail()
+ void setEmail(String)
+ String getAddress()
+ void setAddress(String)
+ long getId()
}


class Feedback {
- {static} AtomicLong nextId
- long id
- long clientId
- String message
- int rating
+ long getId()
+ long getClientId()
+ void setClientId(long)
+ String getMessage()
+ void setMessage(String)
+ int getRating()
+ void setRating(int)
}

class Card {
- {static} AtomicLong nextId
- long id
- long accountId
- String cardNumber
- LocalDate expirationDate
- String cvv
- CardStatus status
+ long getAccountId()
+ void setAccountId(long)
+ long getId()
+ String getCardNumber()
+ String getCvv()
+ CardStatus getStatus()
+ void block()
+ void expire()
+ LocalDate getExpirationDate()
}


class Loan {
- {static} AtomicLong nextId
- long id
- long clientId
- double amount
- double interestRate
- int termMonths
+ long getId()
+ long getClientId()
+ void setClientId(long)
+ double getAmount()
+ void setAmount(double)
+ double getInterestRate()
+ void setInterestRate(double)
+ int getTermMonths()
+ void setTermMonths(int)
}


class Account {
- {static} AtomicLong nextId
- long id
- String accountNumber
- long clientId
- double balance
- AccountStatus status
+ long getId()
+ String getAccountNumber()
+ void setAccountNumber(String)
+ long getClientId()
+ void setClientId(long)
+ double getBalance()
+ void setBalance(double)
+ void changeBalance(double)
+ void block()
+ void activate()
+ Transaction transferTo(Account,double,Currency)
}


class Employee {
- {static} AtomicLong nextId
- long id
- String fullName
- String position
- double salary
+ long getId()
+ String getFullName()
+ void setFullName(String)
+ String getPosition()
+ void setPosition(String)
+ double getSalary()
+ void setSalary(double)
}


class Transaction {
- {static} AtomicLong nextId
- long id
- long fromAccountId
- long toAccountId
- double amount
+ long getId()
+ long getFromAccountId()
+ long getToAccountId()
+ double getAmount()
+ String toString()
}


class BankBranch {
- {static} AtomicLong nextId
- long id
- String branchName
- String address
- String phoneNumber
+ long getId()
+ String getBranchName()
+ void setBranchName(String)
+ String getAddress()
+ void setAddress(String)
+ String getPhoneNumber()
+ void setPhoneNumber(String)
}


class Currency {
- {static} AtomicLong nextId
- long id
- String code
- double exchangeRateToMain
+ long getId()
+ String getCode()
+ void setCode(String)
+ double getExchangeRateToMain()
+ void setExchangeRateToMain(double)
}


class ATM {
- {static} AtomicLong nextId
- long id
- String location
- double cashBalance
+ long getId()
+ String getLocation()
+ void setLocation(String)
+ double getCashBalance()
+ void setCashBalance(double)
+ void changeCashBalance(double)
+ void withdrawCash(Account,double)
+ void putCash(Account,double)
}


enum AccountStatus {
+  ACTIVE
+  BLOCKED
}

enum CardStatus {
+  ACTIVE
+  BLOCKED
+  EXPIRED
}

ATM ..> Account
Account - AccountStatus
Card - CardStatus

@enduml